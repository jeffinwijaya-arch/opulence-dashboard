# Python bytecode / build artifacts (scripts/backend-ref contains a
# Python reference implementation that gets compiled for syntax checks)
__pycache__/
*.py[cod]
*$py.class

# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Local env
.env
.env.local
.env.*.local

# Build output (Cloudflare Pages builds from public/ directly, but be safe)
/dist/
/build/

# Logs
*.log

# Test artifacts
.pytest_cache/
coverage/
.vitest-cache/

# Vision recognition cache (per-image result cache, not committed)
.cache/

# Local databases (the sqlite files in public/ are committed, but ignore
# any local copies agents might create while experimenting)
*.db-journal
*.db-wal
*.db-shm
